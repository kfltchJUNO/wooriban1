rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin()   { return getRole() == 'admin'; }
    function isTeacher() { return getRole() == 'teacher' || isAdmin(); }
    function sameClass(classId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.classId == classId;
    }

    match /users/{uid} {
      allow read: if isAuth() && (isOwner(uid) || isTeacher());
      allow create: if isAuth() && isOwner(uid);
      allow update: if isAdmin()
        || (isOwner(uid) && !request.resource.data.diff(resource.data)
           .affectedKeys().hasAny(['nameKr','role','status','sortOrder']));
    }
    match /schools/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /assignments/{id} {
      allow read: if isAuth() && sameClass(resource.data.classId);
      allow write: if isTeacher();
    }
    match /submissions/{id} {
      allow read: if isAuth() && (isOwner(resource.data.studentUid) || isTeacher());
      allow create: if isAuth() && isOwner(request.resource.data.studentUid);
      allow update: if isTeacher();
    }
    match /feedback/{id} {
      allow read: if isAuth() && (isOwner(resource.data.studentUid) || isTeacher());
      allow write: if isTeacher();
    }
    match /posts/{id} {
      allow read: if isAuth() && sameClass(resource.data.classId);
      allow create: if isAuth();
      allow update: if isAuth() && (isOwner(resource.data.authorUid) || isTeacher());
      allow delete: if isTeacher();
      match /comments/{cid} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow delete: if isAuth() && (isOwner(resource.data.authorUid) || isTeacher());
      }
    }
    match /freeWritings/{id} {
      allow read: if isAuth() && (isOwner(resource.data.studentUid) || isTeacher());
      allow create: if isAuth() && isOwner(request.resource.data.studentUid);
      allow update: if isTeacher();
    }
  }
}
